<!DOCTYPE html>
<html lang="en">

<head>
    {block css}
        <link href="https://fonts.googleapis.com/css2?family=Pacifico&display=swap" rel="stylesheet">
        <link href="https://fonts.googleapis.com/css2?family=Roboto&display=swap" rel="stylesheet">
        <style>
            .pagination {
                display: inline-block;
            }

            .pagination li {
                color: black;
                float: left;
                padding: 8px 16px;
                text-decoration: none;
                border: 1px solid #ddd;
                transition: background-color .3s;
            }

            .pagination li.active a {
                color: white;
            }

            .pagination li.active {
                background-color: #0b58a2;
            }

            .pagination li:hover:not(.active) {
                background-color: #ddd;
            }

            .eventCalendar .ec-event {
                position: absolute;
                display: none;
                padding: 10px;
                margin: 5px 0 0 -5px;
                background: rgba(0,0,0,0.95);
                border: 1px black solid;
            }
            .eventCalendar th {
                background-color: #337AB7;
                border: 1px #165C99 solid;
                color: white;
            }
            .eventCalendar .ec-empty {
                background-color: rgb(200,200,200);
            }
            .eventCalendar .ec-eventDay {
                background-color: #D9534F;
                color: white;
                cursor: pointer;
            }
            .eventCalendar .ec-monthTable caption {
                font-size: 20px;
            }
            .ec-monthTable {
                margin: auto;
                border: 1px #165C99 solid;
            }
            .eventCalendar td {
                border: 1px gray solid;
            }

            .eventCalendar .ec-bottomNavigation {
                margin: 3px 20px 0px 20px;
            }

            body { font-family: 'Roboto', sans-serif; }
            .navbar-brand{ font-family: 'Pacifico', cursive; }

            .list-group a { text-decoration: none; font-weight: 100;text-transform: uppercase; }
            .fill .list-group a { position: relative; }

            .fill .list-group a:after { position: absolute; bottom: 0; left: 0; right: 0; margin: auto;
                width: 0%; content: '.'; color: transparent; height: 1px; }

            .fill .list-group a:hover { z-index: 1; }

            .fill .list-group a:hover:after { z-index: -10; animation: fill 1s forwards;
                -webkit-animation: fill 1s forwards; -moz-animation: fill 1s forwards; opacity: 1; }

            @-webkit-keyframes fill {
                0% { width: 0%; height: 1px; }
                50% { width: 100%; height: 1px; }
                100% { width: 100%; height: 100%; background: #d9534f; }
            }

            .navbar-brand{ font-family: 'Pacifico', cursive; }
            #wrapper {
                overflow-x: hidden;
                background-color: #F5F5F5;
            }
            hr.caraPodNazvem {
                border: 1px solid white;
                margin-bottom: 0;
            }
            .ramecek{
                border-style: solid;
                margin-bottom:15px;
                margin-right: 15px;
                border-width: 3px;
                border-color: black;
            }
            #sidebar-wrapper {
                min-height: 100vh;
                margin-left: -15rem;
                -webkit-transition: margin .25s ease-out;
                -moz-transition: margin .25s ease-out;
                -o-transition: margin .25s ease-out;
                transition: margin .25s ease-out;

            }

            #sidebar-wrapper .sidebar-heading {
                padding: 15px 10px;
                font-size: 1.2rem;
            }

            #sidebar-wrapper .list-group {
                width: 19rem;
                font-size: 16px;

            }

            .list-group .active { background:#0275d8;}

            #page-content-wrapper {
                min-width: 100vw;
            }

            #wrapper.toggled #sidebar-wrapper {
                margin-left: 0;
            }

            @media (min-width: 768px) {
                #sidebar-wrapper {
                    margin-left: 0;
                }

                #page-content-wrapper {
                    min-width: 0;
                    width: 100%;
                }

                #wrapper.toggled #sidebar-wrapper {
                    margin-left: -19rem;
                }
            }


            @media (max-width: 767px) {
                #sidebar-wrapper {
                    margin-left: 15px;
                }

                #page-content-wrapper {
                    min-width: 0;
                    width: 100%;
                }

                #wrapper.toggled #sidebar-wrapper {
                    margin-left: -19rem;
                }
            }
        </style>
        <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
        <link rel="stylesheet" type="text/css" href="https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css">
        <link rel="stylesheet" href="{$baseUrl}/bower_components/grido/assets/dist/css/grido.css" type="text/css">
        <link rel="stylesheet" href="{$baseUrl}/bower_components/jquery-ui/themes/base/jquery-ui.min.css" type="text/css">
        <link rel="stylesheet" href="{$baseUrl}/bower_components/font-awesome/css/font-awesome.min.css" type="text/css">
        <link rel="stylesheet" href="{$baseUrl}/bower_components/bootstrap/dist/css/bootstrap.min.css" type="text/css">
    {/block}

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">

    <title>Kataraz</title>

    {block requiredJs}
        <script src="{$baseUrl}/bower_components/nette.ajax.js/nette.ajax.js" type="text/javascript"></script>
        <script src="https://nette.github.io/resources/js/3/netteForms.min.js"></script>
        <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.5.1/jquery.min.js"></script>
        <script src="https://code.jquery.com/jquery-3.2.1.slim.min.js" integrity="sha384-KJ3o2DKtIkvYIK3UENzmM7KCkRr/rE9/Qpg6aAZGJwFDMVNA/GpGFF93hXpG5KkN" crossorigin="anonymous"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.11.0/umd/popper.min.js" integrity="sha384-b/U6ypiBEHpOf/4+1nzFpr53nxSS+GLCkfwBdFNTxtclqqenISfwAzpKaMNFNmj4" crossorigin="anonymous"></script>
        <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0-beta/js/bootstrap.min.js" integrity="sha384-h0AbiXch4ZDo7tp9hKZ4TsHbi047NrKGLO3SEJAg45jXxnGIfYzk4Si90RDIqNm1" crossorigin="anonymous"></script>
    {/block}
</head>

<body>

<div class="d-flex" id="wrapper">

    <!-- Sidebar -->
    <div class="fill" id="sidebar-wrapper" style="background:rgba(0,0,0,0.85);">
        <div class="sidebar-heading navbar-brand" style="color:rgba(255, 255, 255, 0.95);font-size:25px;margin-left:25px;text-decoration: none"><a n:href="Homepage:default" style="text-decoration: none;color:rgba(255, 255, 255, 0.95);">Kataraz</a></div>
        <div class="list-group list-group-flush">
            <a n:href="Homepage:default" n:class="$presenter->isLinkCurrent('Homepage:default') ? active" style="padding-left:30px;color:rgba(255, 255, 255, 0.95);text-decoration: none;padding-bottom: 16px;padding-top: 16px;font-size: 18px;"><i class="fa fa-th-large" aria-hidden="true"></i> Domovská stránka</a>
            <a n:if="$user->isAllowed('hotel', 'edit')" n:href="Hotel:edit" n:class="$presenter->isLinkCurrent('Hotel:edit') ? active" style="padding-left:30px;color:rgba(255, 255, 255, 0.95);text-decoration: none;padding-bottom: 16px;padding-top: 16px;font-size: 18px;"><i class="fa fa-plus-square-o" aria-hidden="true"></i> Přidat hotel</a>
            <a n:if="$user->isAllowed('room', 'edit')" n:href="Room:edit" n:class="border-bottom, $presenter->isLinkCurrent('Room:edit') ? active" style="padding-left:30px;color:rgba(255, 255, 255, 0.95);text-decoration: none;padding-bottom: 16px;padding-top: 16px;font-size: 18px;"><i class="fa fa-plus-square-o" aria-hidden="true"></i> Přidat pokoj</a>
            <a n:href="Hotel:default" n:class="$presenter->isLinkCurrent('Hotel:default') ? active" style="padding-left:30px;color:rgba(255, 255, 255, 0.95);text-decoration: none;padding-bottom: 16px;padding-top: 16px;font-size: 18px;"><i class="fa fa-list-ol" aria-hidden="true"></i> Seznam hotelů</a>
            <a n:href="Room:default" n:class="border-bottom, $presenter->isLinkCurrent('Room:default') ? active" style="padding-left:30px;color:rgba(255, 255, 255, 0.95);text-decoration: none;padding-bottom: 16px;padding-top: 16px;font-size: 18px;"><i class="fa fa-list-ol" aria-hidden="true"></i> Seznam pokojů</a>
            <a n:if="$user->isInRole(HotelSystem\Model\Repository\UserRepository::ROLE_RECEPTIONIST)" n:class="border-bottom, $presenter->isLinkCurrent('Reservation:default') ? active" n:href="Reservation:default"  style="cursor: pointer;padding-left:30px;color:rgba(255, 255, 255, 0.95);text-decoration: none;padding-bottom: 16px;padding-top: 16px;font-size: 18px;"><i class="fa fa-pie-chart" aria-hidden="true"></i> Přehled rezervací</a>
            <a n:href="User:default" n:class="$presenter->isLinkCurrent('User:default') ? active" n:if="$user->isAllowed('user', 'overview')" style="cursor: pointer;padding-left:30px;color:rgba(255, 255, 255, 0.95);text-decoration: none;padding-bottom: 16px;padding-top: 16px;font-size: 18px;"><i class="fa fa-user-o" aria-hidden="true"></i> Seznam uživatelů</a>
        </div>
    </div>
    <!-- /#sidebar-wrapper -->

    <!-- Page Content -->
    <div id="page-content-wrapper">

        <nav class="navbar navbar-expand-lg navbar-dark border-bottom" style="background:rgba(0,0,0,0.85);">
            <button class="btn btn-danger btn-lg" id="menu-toggle"><i class="fa fa-bars" aria-hidden="true"></i></button>
            <button class="navbar-toggler" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarSupportedContent">
                <ul class="navbar-nav ml-auto mt-2 mt-lg-0">
                    <li class="nav-item">
                        <a n:if="$user->isLoggedIn()" n:href="Reservation:default userId => $user->getId()" class="nav-link" style="color:rgba(255, 255, 255, 0.95);">Moje rezervace</a>
                    </li>
                    <li class="nav-item">
                        <a n:class="nav-link, $presenter->isLinkCurrent('User:edit') ? active" n:href="User:edit userId => $user->getId()" style="color:rgba(255, 255, 255, 0.95);"><i class="fa fa-user-o" aria-hidden="true"></i>
                            {if $user->isLoggedIn()}Profil{else}Registrovat{/if}
                        </a>
                    </li>
                    <li class="nav-item active">
                        {if $user->isLoggedIn()}
                            {control logoutForm}
                        {else}
                            <a n:href="User:login" class="nav-link">Přihlásit se</a>
                        {/if}
                    </li>
                </ul>
            </div>
        </nav>

        {if isset($flashes) && isset($presenter)}
            {snippet flashes}
                <div n:foreach="$flashes as $flash" class="container-fluid" style="margin: 10px;">
                    <div class="alert alert-{str_replace('error', 'danger', $flash->type)} alert-dismissible" role="alert">
                        <button class="close" aria-label="Close" data-dismiss="alert" type="button">
                            <span aria-hidden="true">×</span>
                        </button>
                        {$flash->message|noescape}
                    </div>
                </div>
            {/snippet}
        {/if}

        <div class="container-fluid">
            {include content}
        </div>
    </div>
    <!-- /#page-content-wrapper -->

</div>
<!-- /#wrapper -->
<!-- Bootstrap core JavaScript -->
{block scripts}
    <script type="text/javascript">
        $("#menu-toggle").click(function(e) {
            e.preventDefault();
            $("#wrapper").toggleClass("toggled");
        });
    </script>
{/block}

</body>

</html>
